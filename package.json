{
  "name": "pi-fusion",
  "version": "0.4.0",
  "description": "Multi-model deliberation for pi, inspired by OpenRouter Fusion",
  "type": "module",
  "main": "./src/index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synthetic-recon/pi-fusion.git"
  },
  "bugs": {
    "url": "https://github.com/synthetic-recon/pi-fusion/issues"
  },
  "homepage": "https://github.com/synthetic-recon/pi-fusion#readme",
  "keywords": ["pi-package", "pi-extension", "fusion", "multi-model", "coding-agent", "llm", "openrouter"],
  "license": "MIT",
  "files": [
    "src/*.ts",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf node_modules",
    "build": "echo 'pi-fusion is loaded directly by pi via jiti; no build step required'",
    "check": "tsc --noEmit",
    "test": "node --import jiti/register src/__tests__/utils.test.ts src/__tests__/config.test.ts src/__tests__/models.test.ts src/__tests__/format.test.ts src/__tests__/llm.test.ts src/__tests__/context.test.ts"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {},
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "jiti": "^2.4.0",
    "typescript": "^5.5.0"
  }
}
